# ══════════════════════════════════════════════
# MenuPro — Staging Environment
# ══════════════════════════════════════════════
# Copy this file to .env.staging and update values
# Usage: vercel env pull .env.staging --environment preview

# ─── Database (Neon Staging Branch) ───
# Create a staging branch in Neon Dashboard → Branches → Create Branch
DATABASE_URL="postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/neondb_staging?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/neondb_staging?sslmode=require"

# ─── NextAuth ───
NEXTAUTH_URL="https://staging.menupro.app"
NEXTAUTH_SECRET="GENERATE_A_UNIQUE_STAGING_SECRET_HERE"
AUTH_SECRET="GENERATE_A_UNIQUE_STAGING_SECRET_HERE"

# ─── App ───
NEXT_PUBLIC_APP_URL="https://staging.menupro.app"
NEXT_PUBLIC_APP_NAME="MenuPro [Staging]"
NEXT_PUBLIC_ENV="staging"

# ─── Upstash Redis (Rate Limiting) ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Sentry (Error Monitoring) ───
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── Vercel Blob (Image Uploads) ───
BLOB_READ_WRITE_TOKEN=""
